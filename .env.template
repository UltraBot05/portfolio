# 🔑 ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Gemini API Key
# ============================================
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ============================================
# OPTIONAL: Environment Configuration
# ============================================
NODE_ENV=development

# ============================================
# OPTIONAL: CORS Configuration (for production)
# ============================================
# Set this to your production frontend URL
# Example: FRONTEND_URL=https://your-site.vercel.app
FRONTEND_URL=

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.template .env
# 2. Get Gemini API key: https://makersuite.google.com/app/apikey
# 3. Paste your API key after GEMINI_API_KEY=
# 4. Save the file
# 5. Run: npm run server (backend) and npm run dev (frontend)
#
# For Vercel deployment:
# - Add GEMINI_API_KEY in Vercel Dashboard → Settings → Environment Variables
# - Add FRONTEND_URL with your Vercel domain (optional)
